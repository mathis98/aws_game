{
    "compilerOptions": {
        "outDir": "./dist/",
        "sourceMap": true,
        "noImplicitAny": true,
        "module": "commonjs",
        "target": "es6",
        "jsx": "react",
        "baseUrl": ".",
        "paths": {
            "components/*": [
                "src/components/*",
            ],
            "pages/*": [
                "src/pages/*",
            ],
            "level_data/*": [
                "level_data/*",
            ],
            "levels/*": [
                "src/levels/*",
            ],
        }
    },
    "include": [
        "src",
        "level_data"
    ]
}
